{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure r-vec",
            "type": "shell",
            "command": "cmake",
            "args": [
                "-S",
                "${workspaceFolder}/software/r-vec",
                "-B",
                "${workspaceFolder}/build/r-vec"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Build r-vec",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build/r-vec",
                "--target",
                "r-vec"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "Configure r-vec",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "Build vector-repl",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build",
                "${workspaceFolder}/build/vector-repl",
                "--target",
                "vector-repl"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}
